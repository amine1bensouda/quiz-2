DATABASE_URL=
DIRECT_URL=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Admin authentication
# Préférer ADMIN_PASSWORD_HASH (bcrypt). Générer avec: npm run admin:hash -- "your-password"
# ADMIN_PASSWORD reste supporté en fallback (dev uniquement, à ne PAS utiliser en prod).
ADMIN_PASSWORD=
ADMIN_PASSWORD_HASH=
# Secret pour signer le cookie de session admin (HMAC). Chaîne aléatoire longue.
ADMIN_SESSION_SECRET=

# Cloudflare R2 (S3 compatible)
R2_ACCOUNT_ID=
# Optional override (sinon construit avec R2_ACCOUNT_ID)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Custom domain or R2.dev public URL, without trailing slash
R2_PUBLIC_BASE_URL=

# ------------------------------------------------------------------
# Course subscriptions — Stripe
# Get keys from https://dashboard.stripe.com/apikeys
# STRIPE_WEBHOOK_SECRET is displayed when you create a webhook endpoint
# pointing to /api/payments/stripe/webhook (use `stripe listen` in dev).
# Create two recurring prices (monthly, USD) on Stripe:
#   - $7/mo  -> STRIPE_PRICE_SINGLE_COURSE_ID=price_xxx
#   - $25/mo -> STRIPE_PRICE_ALL_ACCESS_ID=price_xxx
# STRIPE_BILLING_PORTAL_RETURN_URL: full URL (https://yourdomain.com/dashboard) where Stripe
# sends users after the Customer Portal. Must match a domain allowed in
# Stripe Dashboard → Settings → Customer portal → Allowed redirect domains.
# If unset, we use NEXT_PUBLIC_APP_URL (or SITE_URL) + /dashboard?from=stripe-portal
# STRIPE_BILLING_PORTAL_CONFIGURATION_ID: optional. Billing Portal → Create configuration
# to set headline/logo; session uses locale=en in code. Merchant display name on the portal
# follows Stripe Dashboard → Settings → Business / public account details.
# ------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_SINGLE_COURSE_ID=
STRIPE_PRICE_ALL_ACCESS_ID=
STRIPE_BILLING_PORTAL_RETURN_URL=
STRIPE_BILLING_PORTAL_CONFIGURATION_ID=

# ------------------------------------------------------------------
# Course subscriptions — PayPal (Billing API)
# Create a REST app at https://developer.paypal.com/dashboard/applications/sandbox
# PAYPAL_ENV: "sandbox" (default) or "live"
# Both PAYPAL_CLIENT_ID and NEXT_PUBLIC_PAYPAL_CLIENT_ID must be set to the same value
# (the public one is used by the browser to load the PayPal JS SDK).
# Run `npx tsx scripts/paypal-setup-plans.ts` once to create billing plans
# with a 2-day free trial, then copy the plan IDs below.
# PAYPAL_WEBHOOK_ID is required to verify webhook signatures.
# ------------------------------------------------------------------
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_PLAN_SINGLE_COURSE_ID=
PAYPAL_PLAN_ALL_ACCESS_ID=
PAYPAL_WEBHOOK_ID=
