# ===========================================
# Configuration .env pour Hostinger
# ===========================================
# 1. Copier ce fichier et le renommer en .env
# 2. Remplacer les valeurs entre guillemets par vos vraies données
# 3. Sur Hostinger : ajouter ces variables dans le panneau (Variables d'environnement)
#    IMPORTANT : DATABASE_URL doit être disponible PENDANT LE BUILD (pas seulement au runtime).
#    Sinon le build échoue avec "Environment variable not found: DATABASE_URL".
# Voir HOSTINGER_DEPLOY.md pour le déploiement.
# ===========================================

# --- Base de données (OBLIGATOIRE pour build ET runtime) ---
# URL PostgreSQL (Hostinger propose PostgreSQL, ou utilisez Supabase/Neon)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# --- URL du site (OBLIGATOIRE pour les uploads et liens) ---
# URL publique de votre site (sans slash final)
NEXT_PUBLIC_SITE_URL="https://votredomaine.com"

# --- Admin (recommandé en production) ---
# Mot de passe pour /admin/login (changer le défaut)
ADMIN_PASSWORD="votre_mot_de_passe_admin_securise"

# --- WordPress / Tutor LMS (optionnel, ignorer si non utilisé) ---
# Uniquement si vous utilisez WordPress ou Tutor LMS pour quiz/catégories
# WORDPRESS_API_URL="https://votresite.com/wp-json"

# --- Revalidation (optionnel) ---
# REVALIDATE_SECRET="un_secret_aleatoire"

# --- Analytics / Ads (optionnel) ---
# NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"
# NEXT_PUBLIC_ADSENSE_CLIENT_ID="ca-pub-xxxxxxxx"
# NEXT_PUBLIC_ADSENSE_DISPLAY_SLOT="1234567890"
# NEXT_PUBLIC_ADSENSE_SIDEBAR_SLOT="1234567890"
# NEXT_PUBLIC_ADSENSE_INARTICLE_SLOT="1234567891"

# --- Cache (optionnel) ---
# NEXT_REVALIDATE_TIME=3600
